{
  "name": "@infra-blocks/toolkit",
  "version": "0.2.0",
  "description": "Various low-level utilities that aim at maximizing code reuse.",
  "keywords": [
    "toolkit",
    "utilities"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/infra-blocks/ts-toolkit.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "default": "./lib/esm/index.js"
    },
    "./typeof": {
      "import": "./lib/esm/typeof/index.js",
      "require": "./lib/cjs/typeof/index.js",
      "default": "./lib/esm/typeof/index.js"
    }
  },
  "main": "./lib/cjs/index.js",
  "files": [
    "lib/**/*.{js,cjs,mjs,json,d.ts,map}"
  ],
  "scripts": {
    "prepack": "mise run build"
  },
  "devDependencies": {
    "@infra-blocks/test": "^0.10.0",
    "@infra-blocks/types": "^0.33.0",
    "@types/node": "^24.12.0",
    "c8": "^10.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "es-toolkit": "^1.45.1"
  }
}
